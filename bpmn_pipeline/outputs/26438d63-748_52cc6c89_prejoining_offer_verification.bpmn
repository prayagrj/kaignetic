    <startEvent id="start_1ae3b28f" name="Start"/>
    <userTask id="task_b5aa1335" name="Send the offer letter to the selected candidate within 2 business days of verbal offer confirmation."/>
    <userTask id="task_8c702261" name="Track the acceptance status of the offer letter."/>
    <userTask id="task_2f1674e5" name="Send a reminder email to the candidate."/>
    <userTask id="task_8f40aeee" name="Notify the Hiring Manager and close the position."/>
    <userTask id="task_019e362a" name="Initiate the Background Verification process by submitting the candidate's details to the external BGV agency."/>
    <userTask id="task_519f8723" name="Share the pre‑joining document checklist with the candidate via email."/>
    <userTask id="task_4f62e65a" name="Review the submitted documents."/>
    <userTask id="task_3b9b35f4" name="Send a document deficiency notice to the candidate and request resubmission within 2 business days."/>
    <userTask id="task_983ca497" name="Escalate to the HR Manager for a decision on whether to defer or cancel the joining."/>
    <exclusiveGateway id="gateway_b96a38b9" name="BGV report outcome decision"/>
    <userTask id="task_079623b4" name="Proceed with onboarding preparation"/>
    <userTask id="task_6650b68e" name="Escalate the BGV report to the HR Manager and the Legal team for review"/>
    <userTask id="task_9938e132" name="Place the joining on hold until the review is complete"/>
    <userTask id="task_9309b884" name="Proceed with a conditional joining, subject to HR Manager approval"/>
    <userTask id="task_3c4e751c" name="Raise an IT request in the ticketing system including employee name, joining date, department, designation, and…"/>
    <exclusiveGateway id="gateway_32dcda4f" name="Standard vs Custom IT configuration"/>
    <userTask id="task_afe6bee2" name="Prepare the laptop and create system accounts"/>
    <userTask id="task_dab02df7" name="Notify HR Business Partner and Hiring Manager that a custom configuration is required"/>
    <exclusiveGateway id="gateway_660d39ef" name="Approve custom configuration"/>
    <userTask id="task_fd48ceb7" name="Fulfill the IT request"/>
    <userTask id="task_02ae0dcf" name="Ensure laptop with OS configured, corporate email account, VPN access, and access to standard productivity tools are…"/>
    <userTask id="task_23718f81" name="Notify HR Business Partner immediately"/>
    <exclusiveGateway id="gateway_d9e472fe" name="Decision to defer joining date or use temporary setup"/>
    <endEvent id="end_841130d5" name="End"/>
