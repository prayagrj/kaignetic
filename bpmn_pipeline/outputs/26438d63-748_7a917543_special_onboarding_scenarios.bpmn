    <sequenceFlow id="flow_14b0ef96" sourceRef="gateway_b84e1c84" targetRef="task_c0257015" name="Deferral request exceeds 30 days (requires manager approval)">
      <conditionExpression>${V_deferral_request} == exceeds 30 days</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_6fdb4a59" sourceRef="gateway_b84e1c84" targetRef="task_67b2a92e" name="Approved (≤30 days)">
      <conditionExpression>${V_deferral_approved} == true</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_8865eec1" sourceRef="gateway_b84e1c84" targetRef="task_d8d47a0d" name="Not approved">
      <conditionExpression>${V_deferral_approved} == false</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_45dafab8" sourceRef="gateway_c61df643" targetRef="gateway_cg_78728b" name="Minor and explainable">
      <conditionExpression>${V_is_minor} == true</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_8c505f46" sourceRef="gateway_c61df643" targetRef="task_968ddf86" name="Material">
      <conditionExpression>${V_is_minor} == false</conditionExpression>
    </sequenceFlow>
