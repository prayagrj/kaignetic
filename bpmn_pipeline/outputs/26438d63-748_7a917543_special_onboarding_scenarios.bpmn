    <startEvent id="start_e650e78c" name="Start"/>
    <userTask id="task_ea339aa6" name="Confirm the employee's shipping address with the employee."/>
    <userTask id="task_2f8c13ca" name="Share all induction materials digitally with the employee before the session."/>
    <userTask id="task_302cd130" name="Ship the laptop to the employee's registered address at least two business days before the joining date."/>
    <userTask id="task_da839370" name="Conduct document collection via the HR portal."/>
    <userTask id="task_8afc8d84" name="Replace original document verification with a self‑attestation declaration."/>
    <userTask id="task_ff1f6089" name="Conduct the HR induction session via video conferencing."/>
    <userTask id="task_1689ad60" name="Review the candidate's deferral request"/>
    <userTask id="task_294e44e2" name="Consult with the Hiring Manager on whether the deferral is operationally feasible"/>
    <exclusiveGateway id="gateway_b84e1c84" name="Deferral approval decision"/>
    <userTask id="task_c0257015" name="Approve the deferral request"/>
    <userTask id="task_67b2a92e" name="Update the joining date in the system"/>
    <userTask id="task_3c41eee7" name="Notify IT Helpdesk to reschedule the IT setup"/>
    <userTask id="task_a0794991" name="Confirm the new joining date with the candidate"/>
    <userTask id="task_d8d47a0d" name="Inform the candidate that the original joining date must be maintained"/>
    <userTask id="task_69ac89f8" name="Treat the situation as an offer decline"/>
    <userTask id="task_467d390d" name="Notify the HR Manager and Legal team of the BGV discrepancy"/>
    <userTask id="task_b8d50e63" name="Assess the nature of the BGV discrepancy"/>
    <exclusiveGateway id="gateway_c61df643" name="BGV discrepancy assessment outcome"/>
    <userTask id="task_873712f7" name="Document the finding and the employee's explanation"/>
    <userTask id="task_a7df38e6" name="Close the BGV case and update the employee record"/>
    <userTask id="task_968ddf86" name="Initiate a disciplinary review"/>
    <userTask id="task_30169f5a" name="Place the employee on administrative leave pending the outcome"/>
    <endEvent id="end_e1a30676" name="End"/>
    <exclusiveGateway id="gateway_cg_c15b45" name=""/>
    <exclusiveGateway id="gateway_cg_78728b" name=""/>
    <exclusiveGateway id="gateway_cg_8b9606" name=""/>
