    <startEvent id="start_03cd19cc" name="Start"/>
    <userTask id="task_2a1b22a2" name="Greet the new employee at the office reception."/>
    <userTask id="task_98e7f88c" name="Escort the new employee to the HR area."/>
    <userTask id="task_5ce116c3" name="Collect the original copies of all submitted documents for verification."/>
    <userTask id="task_4c1ab390" name="Return the original documents to the employee after review."/>
    <userTask id="task_d9e02946" name="Obtain the employee's signature on the employment contract, confidentiality and non‑disclosure agreement, IT acceptable…"/>
    <userTask id="task_6ec2a0b0" name="Pause the signing process."/>
    <userTask id="task_edfc6599" name="Notify the HR Manager of the objection."/>
    <exclusiveGateway id="gateway_31c4697f" name="Objection handling decision"/>
    <userTask id="task_2be61f3f" name="Create the employee's profile in the HRMS."/>
    <userTask id="task_9871e4bf" name="Assign the employee ID."/>
    <userTask id="task_ad116d39" name="Hand over the IT assets to the employee."/>
    <userTask id="task_f0450ef2" name="Obtain the employee's signature on the IT asset acknowledgement form."/>
    <userTask id="task_d9847e69" name="Conduct the HR induction session covering organisation overview, HR policies, leave policy, code of conduct, grievance…"/>
    <userTask id="task_47a63ebe" name="Conduct the department induction session covering team structure, ongoing projects, tools used by the team, and the…"/>
    <userTask id="task_3eaa8bfc" name="Introduce the new employee to their assigned buddy."/>
    <userTask id="task_987dae6f" name="Send the employee's bank account details and salary structure to the Finance Team on the joining day."/>
    <userTask id="task_86c21009" name="Verify the employee's bank account details."/>
    <userTask id="task_944e9cc5" name="Contact the employee directly to collect correct bank account information."/>
    <userTask id="task_8450eee9" name="Add the employee to the payroll system."/>
    <userTask id="task_3dae4f71" name="Add the employee to the next month's payroll cycle."/>
    <userTask id="task_dbe3f7b9" name="Confirm payroll addition to the HR Business Partner within 2 business days of receiving the bank details."/>
    <endEvent id="end_bdf89446" name="End"/>
