    <startEvent id="start_92011196" name="Start"/>
    <userTask id="task_80418575" name="Assign the mandatory e‑learning modules (Information Security Awareness, Prevention of Sexual Harassment (POSH),…"/>
    <userTask id="task_b390b60e" name="Monitor the employee’s training completion status weekly via the LMS dashboard."/>
    <userTask id="task_117678b0" name="Send a reminder to the employee and copy the Hiring Manager."/>
    <userTask id="task_57f93bcc" name="Escalate the incomplete training issue to the HR Manager."/>
    <userTask id="task_55eed2dd" name="Notify the employee formally that non‑completion may affect their probation assessment."/>
    <userTask id="task_a3df9b3e" name="Follow up with the employee to confirm that all system accesses are working correctly."/>
    <userTask id="task_e900aaa8" name="Raise a follow-up IT ticket with the IT Helpdesk and mark it as high priority."/>
    <userTask id="task_3a9f0c28" name="Escalate the unresolved access issue to the IT Manager."/>
    <userTask id="task_06c055ff" name="Send the 30-day feedback form to the new employee and the Hiring Manager."/>
    <userTask id="task_688443bf" name="Send a reminder for the 30-day feedback form."/>
    <userTask id="task_43d30c81" name="Conduct a 30-day check-in meeting with the employee."/>
    <exclusiveGateway id="gateway_af1e7d85" name="Hiring Manager feedback decision"/>
    <userTask id="task_e9b94ef5" name="Mark the onboarding checklist as complete in the HRMS."/>
    <userTask id="task_27ee1ddc" name="Archive all onboarding documents in the employee's digital file on the HR document management system."/>
    <userTask id="task_c61bd6b0" name="Send a completion confirmation email to the Hiring Manager and the HR Manager."/>
    <endEvent id="end_ce1e791c" name="End"/>
    <exclusiveGateway id="gateway_cg_727641" name=""/>
    <exclusiveGateway id="gateway_cg_c78e64" name=""/>
