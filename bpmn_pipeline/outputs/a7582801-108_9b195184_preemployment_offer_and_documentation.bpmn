    <sequenceFlow id="flow_129d8fda" sourceRef="gateway_e9fc50e1" targetRef="task_c3f53bd0" name="Custom configuration">
      <conditionExpression>${V_is_standard_config} == false</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_ab269d2b" sourceRef="gateway_91816d63" targetRef="gateway_a3f82a58" name="Defer joining date">
