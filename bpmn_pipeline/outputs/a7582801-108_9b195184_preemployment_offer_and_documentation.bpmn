    <sequenceFlow id="flow_000b505f" sourceRef="gateway_ec5ec9a6" targetRef="gateway_aa5fa925" name="Candidate did not respond within 5 business days – send reminder email">
      <conditionExpression>${V_follow_up_needed} == true</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_a060c0fd" sourceRef="gateway_ec5ec9a6" targetRef="gateway_5fc69d45" name="Candidate responded within 5 business days – proceed with offer decision">
      <conditionExpression>${V_follow_up_needed} == false</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_5e424d1e" sourceRef="gateway_5fc69d45" targetRef="subprocess_25128c06" name="Candidate declines offer">
      <conditionExpression>${V_offer_response_status} == declined</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_5b3f8043" sourceRef="gateway_5fc69d45" targetRef="subprocess_25128c06" name="Candidate accepts offer" isDefault="true"/>
    <sequenceFlow id="flow_dfa0654b" sourceRef="subprocess_25128c06" targetRef="subprocess_25128c06" name="Candidate accepts the offer">
      <conditionExpression>${V_offer_response_status} == true</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_ec696039" sourceRef="subprocess_25128c06" targetRef="task_75faa0d8" name="Candidate does not accept the offer">
      <conditionExpression>${V_offer_response_status} == false</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_f9d9f465" sourceRef="gateway_022609e6" targetRef="task_e0b5b4f0" name="Documents complete">
