    <sequenceFlow id="flow_5a41c601" sourceRef="gateway_606be339" targetRef="task_162eeb16" name="BGV report flags a discrepancy">
      <conditionExpression>${V_bgv_status} == discrepancy</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_10621d51" sourceRef="gateway_606be339" targetRef="task_162eeb16" name="BGV report delayed beyond 10 business days">
      <conditionExpression>${V_bgv_status} == delayed</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_48845f49" sourceRef="gateway_e9fc50e1" targetRef="task_c3f53bd0" name="Standard configuration">
      <conditionExpression>${V_is_standard_config} == true</conditionExpression>
