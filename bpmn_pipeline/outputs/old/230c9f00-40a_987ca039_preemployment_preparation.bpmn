    <sequenceFlow id="flow_1669e3e8" sourceRef="gateway_9cc76e1e" targetRef="gateway_bffee76c" name="Candidate has not responded within 5 business days">
      <conditionExpression>${V_candidate_no_response} == true</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_07347baf" sourceRef="gateway_9cc76e1e" targetRef="gateway_20623fc3" name="Candidate responded (or responded within 5 business days)">
      <conditionExpression>${V_candidate_no_response} == false</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_f279e8ec" sourceRef="gateway_20623fc3" targetRef="gateway_2165f671" name="Candidate declines the offer">
      <conditionExpression>${V_candidate_declined} == true</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_ac085a7f" sourceRef="gateway_20623fc3" targetRef="gateway_2165f671" name="Candidate does not decline the offer" isDefault="true">
      <conditionExpression>${V_candidate_declined} == false</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_dd144e7e" sourceRef="gateway_2165f671" targetRef="task_6fc3ad4d" name="candidate accepts the offer">
      <conditionExpression>${V_candidate_accepted} == true</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_98db5238" sourceRef="subprocess_dee8b51a" targetRef="subprocess_dee8b51a" name="Documents incomplete after 2 business days">
      <conditionExpression>${V_documents_complete} == true</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_e6020d88" sourceRef="subprocess_dee8b51a" targetRef="task_b8c4ecab" name="Documents complete within 2 business days">
      <conditionExpression>${V_documents_complete} == True</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_27a3c7bc" sourceRef="gateway_e9070c51" targetRef="task_10b5dbbf" name="BGV report is clear">
      <conditionExpression>${V_bgv_outcome} == clear</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_bd59b6c2" sourceRef="gateway_e9070c51" targetRef="task_10b5dbbf" name="BGV report flags a discrepancy">
      <conditionExpression>${V_bgv_outcome} == discrepancy</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_2f185875" sourceRef="gateway_e9070c51" targetRef="task_10b5dbbf" name="BGV report cannot be completed within 10 business days (agency delay)">
      <conditionExpression>${V_bgv_outcome} == delay</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_43de29b9" sourceRef="gateway_ef1a93b5" targetRef="task_e95854cc" name="Standard hardware configuration applies">
      <conditionExpression>${V_is_standard_config} == true</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_161f65af" sourceRef="gateway_ef1a93b5" targetRef="subprocess_f8f8f31b" name="Custom hardware configuration needed">
      <conditionExpression>${V_is_standard_config} == false</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_9489e1d9" sourceRef="subprocess_f8f8f31b" targetRef="subprocess_f8f8f31b" name="IT setup not ready">
      <conditionExpression>${V_it_setup_ready} == false</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_2520f1f5" sourceRef="task_90dc7c83" targetRef="subprocess_dee8b51a" name="Documents incomplete or invalid"/>
    <sequenceFlow id="flow_0d15ab02" sourceRef="subprocess_f8f8f31b" targetRef="end_a86c6e41" name="IT setup ready"/>
