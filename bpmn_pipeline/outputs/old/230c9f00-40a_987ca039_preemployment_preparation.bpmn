    <startEvent id="start_43ffac38" name="Start"/>
    <userTask id="task_614c178a" name="send offer letter to selected candidate"/>
    <exclusiveGateway id="gateway_9cc76e1e" name="track acceptance of the offer letter"/>
    <exclusiveGateway id="gateway_bffee76c" name="evaluate whether candidate has not responded…"/>
    <exclusiveGateway id="gateway_20623fc3" name="evaluate whether candidate declines the offer"/>
    <exclusiveGateway id="gateway_2165f671" name="evaluate whether candidate accepts the offer"/>
    <userTask id="task_6fc3ad4d" name="share pre‑joining document checklist via…"/>
    <userTask id="task_90dc7c83" name="receive candidate's submitted documents…"/>
    <subProcess id="subprocess_dee8b51a" name="escalate incomplete documents to HR Manager…"/>
    <userTask id="task_b8c4ecab" name="conduct verification of employment history,…"/>
    <userTask id="task_5fb7db07" name="receive verification report from BGV agency"/>
    <exclusiveGateway id="gateway_e9070c51" name="review BGV report and determine outcome"/>
    <userTask id="task_10b5dbbf" name="raise IT request in ticketing system"/>
    <exclusiveGateway id="gateway_ef1a93b5" name="review IT request and determine hardware…"/>
    <userTask id="task_e95854cc" name="ensure laptop, email, VPN, and productivity…"/>
    <subProcess id="subprocess_f8f8f31b" name="notify HR Business Partner that IT setup is…"/>
    <endEvent id="end_a86c6e41" name="End"/>
    <sequenceFlow id="flow_df47561e" sourceRef="start_43ffac38" targetRef="task_614c178a"/>
